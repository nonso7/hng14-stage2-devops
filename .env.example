# Compose project name (used as container name prefix)
COMPOSE_PROJECT_NAME=jobapp

# Image names and tag (CI replaces IMAGE_TAG with the git SHA)
API_IMAGE=job-api
WORKER_IMAGE=job-worker
FRONTEND_IMAGE=job-frontend
IMAGE_TAG=latest

# Redis connection (internal only; Redis is NOT exposed to the host)
REDIS_HOST=redis
REDIS_PORT=6379
QUEUE_KEY=job_queue

# Worker tuning
HEARTBEAT_KEY=worker:heartbeat
HEARTBEAT_TTL=15
JOB_DURATION=2

# Frontend -> API URL (service DNS on the backend network)
API_URL=http://api:8000

# Host-facing ports
API_PORT=8000
FRONTEND_PORT=3000
